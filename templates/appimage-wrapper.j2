#!/bin/bash
# AppImage wrapper script for {{ item.appimage_alias }}
# Generated by Ansible

APPIMAGE_PATH="/opt/appimage/{{ item.appimage_url | basename }}"

# Check if AppImage exists
if [ ! -f "$APPIMAGE_PATH" ]; then
    echo "Error: AppImage not found at $APPIMAGE_PATH" >&2
    exit 1
fi

# Launch the AppImage with all arguments
exec "$APPIMAGE_PATH" "$@"
