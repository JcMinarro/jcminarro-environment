# {{ ansible_managed }}
# Zsh configuration file

# ============================================
# PATH CONFIGURATION
# ============================================

# User local bin
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

# Homebrew (macOS Apple Silicon)
if [[ -d "/opt/homebrew/bin" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Homebrew (macOS Intel)
if [[ -d "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# SDKMan
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

# Node version manager (n)
export N_PREFIX="$HOME/n"
[[ :$PATH: == *":$N_PREFIX/bin:"* ]] || PATH="$N_PREFIX/bin:$PATH"

# OpenCode
export PATH="$HOME/.opencode/bin:$PATH"

# ============================================
# OH-MY-ZSH CONFIGURATION (if installed)
# ============================================

# Path to Oh My Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Theme
ZSH_THEME="robbyrussell"

# Plugins
plugins=(
    git
    docker
    docker-compose
    npm
    nvm
    sudo
    history
    colored-man-pages
    z
    extract
    encode64
)

# Load Oh My Zsh if it exists
if [[ -f $ZSH/oh-my-zsh.sh ]]; then
    source $ZSH/oh-my-zsh.sh
fi

# ============================================
# ALIASES
# ============================================

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# List files
alias ls='ls -G'  # macOS color output
alias ll='ls -lah'
alias la='ls -A'

# Git
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph'

# Docker
alias d='docker'
alias dc='docker compose'
alias dps='docker ps'

# Utilities
alias h='history'
alias c='clear'
alias grep='grep --color=auto'
alias df='df -h'
alias du='du -h'

# ============================================
# FUNCTIONS
# ============================================

# Create directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract various archive formats
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1" ;;
            *.tar.gz)    tar xzf "$1" ;;
            *.bz2)       bunzip2 "$1" ;;
            *.rar)       unrar x "$1" ;;
            *.gz)        gunzip "$1" ;;
            *.tar)       tar xf "$1" ;;
            *.tbz2)      tar xjf "$1" ;;
            *.tgz)       tar xzf "$1" ;;
            *.zip)       unzip "$1" ;;
            *.Z)         uncompress "$1" ;;
            *.7z)        7z x "$1" ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# ============================================
# ENVIRONMENT SETTINGS
# ============================================

# Editor
export EDITOR='vim'
export VISUAL='vim'

# Locale
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# History settings
export HISTSIZE=10000
export HISTFILESIZE=20000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt APPEND_HISTORY
setopt SHARE_HISTORY

# Enable colors in terminal
export TERM=xterm-256color
export CLICOLOR=1
export LSCOLORS=ExFxBxDxCxegedabagacad

# Less options
export LESS='-R -i -g -c -W -F -X'

# ============================================
# PLATFORM-SPECIFIC SETTINGS (macOS)
# ============================================

if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS-specific settings
    
    # Enable zsh completion from Homebrew
    if [[ -d /opt/homebrew/share/zsh/site-functions ]]; then
        fpath+=(/opt/homebrew/share/zsh/site-functions)
    elif [[ -d /usr/local/share/zsh/site-functions ]]; then
        fpath+=(/usr/local/share/zsh/site-functions)
    fi
    
    # Disable zsh warning about bashisms
    ZSH_DISABLE_COMPFIX=true
fi

# ============================================
# CUSTOM CONFIGURATIONS
# ============================================

# Load local custom configurations if they exist
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
[[ -f ~/.zsh_aliases ]] && source ~/.zsh_aliases
[[ -f ~/.zsh_functions ]] && source ~/.zsh_functions